{
  "name": "dev-janitor-v2",
  "description": "Cross-platform desktop application for cleaning development artifacts and managing local developer tools.",
  "private": true,
  "author": "cocojojo5213",
  "license": "MIT",
  "version": "2.5.0",
  "packageManager": "pnpm@11.15.1",
  "homepage": "https://github.com/cocojojo5213/Dev-Janitor",
  "repository": {
    "type": "git",
    "url": "https://github.com/cocojojo5213/Dev-Janitor.git"
  },
  "bugs": {
    "url": "https://github.com/cocojojo5213/Dev-Janitor/issues"
  },
  "engines": {
    "node": ">=24 <25",
    "pnpm": ">=11.15.1"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "tsc --noEmit",
    "test": "pnpm test:rust",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml --locked --no-default-features --lib",
    "test:rust:full": "cargo test --manifest-path src-tauri/Cargo.toml --locked",
    "validate:release": "node scripts/validate-release-version.mjs",
    "validate:ai-catalog": "node scripts/audit-ai-catalog.mjs",
    "validate:artifacts": "node scripts/validate-release-artifacts.mjs",
    "tauri": "tauri"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.20",
    "@tauri-apps/api": "2.11.1",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "i18next": "^26.3.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.10",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.4",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "typescript": "~7.0.2",
    "vite": "^8.1.5"
  }
}
